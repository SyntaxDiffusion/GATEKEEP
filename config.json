{
  "app": {
    "host": "127.0.0.1",
    "port": 8443,
    "debug": false,
    "log_level": "INFO",
    "database_path": "data/gatekeep.db",
    "static_files_path": "frontend"
  },
  "network": {
    "scan_timeout": 30,
    "arp_timeout": 3,
    "port_scan_timeout": 2,
    "max_concurrent_port_scans": 50,
    "ports": {
      "common": [21, 22, 23, 25, 53, 80, 443, 445, 3389, 8080, 8443],
      "apt28_indicators": [56777, 35681],
      "iot_common": [1883, 5683, 8883, 9100]
    }
  },
  "dns": {
    "test_domains": [
      "www.google.com",
      "www.microsoft.com",
      "www.cloudflare.com"
    ],
    "trusted_resolvers": [
      "8.8.8.8",
      "8.8.4.4",
      "1.1.1.1",
      "1.0.0.1",
      "9.9.9.9"
    ],
    "check_interval": 60
  },
  "ai": {
    "model": "claude-sonnet-4-6",
    "max_tokens": 16000,
    "temperature": 0.2,
    "timeout": 60
  },
  "monitoring": {
    "anomaly_thresholds": {
      "port_scan": {
        "port_count": 15,
        "time_window": 10
      },
      "syn_flood": {
        "syn_count": 200,
        "time_window": 5
      },
      "dns_tunneling": {
        "entropy_threshold": 4.5,
        "min_length": 50
      }
    }
  },
  "alerts": {
    "severity_escalation": {
      "ioc_match": "critical",
      "apt28_port": "critical",
      "dns_hijack": "critical",
      "port_scan": "medium",
      "syn_flood": "high",
      "dns_tunnel": "high",
      "vulnerable_router": "high"
    }
  },
  "websocket": {
    "heartbeat_interval": 30,
    "timeout": 10,
    "max_connections": 10
  }
}
